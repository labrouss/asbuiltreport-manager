[Unit]
Description=AsBuiltReport Manager — Management Console (tty1)
After=multi-user.target asbuiltreport-manager.service
Wants=asbuiltreport-manager.service

[Service]
Type=simple
ExecStart=/usr/local/bin/abr-console.sh
StandardInput=tty
StandardOutput=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
