#!/bin/sh
# vmware-rpctool — delegates to open-vm-tools inside the vmware-tools container
# The container runs with privileged + host PID which gives it real VMware
# backdoor access that works on ESXi even when the host kernel restricts IOPL.

CONTAINER="asbuiltreport-vmware-tools"

# Check if container is running
if docker inspect --format='{{.State.Running}}' "$CONTAINER" 2>/dev/null | grep -q true; then
    exec docker exec "$CONTAINER" vmware-rpctool "$@"
fi

# Container not ready — try the compiled binary as fallback
if [ -x /usr/bin/vmware-rpctool ]; then
    exec /usr/bin/vmware-rpctool "$@"
fi

exit 1
