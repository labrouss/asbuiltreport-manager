#!/bin/sh
# /etc/init.d/S30docker — Start Docker daemon

PIDFILE=/var/run/dockerd.pid
LOGFILE=/var/log/dockerd.log
DOCKER_OPTS="--storage-driver=overlay2 \
  --log-driver=json-file \
  --log-opt max-size=50m \
  --log-opt max-file=3 \
  --iptables=true \
  --ip-forward=true"

case "$1" in
  start)
    echo "Starting Docker..."

    # Ensure /var/lib/docker exists (may be missing on first boot before resize)
    mkdir -p /var/lib/docker

    # Mount cgroup2 (required by containerd/runc)
    if ! mountpoint -q /sys/fs/cgroup 2>/dev/null; then
      mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || \
        mount -t cgroup  none /sys/fs/cgroup -o all 2>/dev/null || true
    fi

    # Load kernel modules needed by Docker networking
    modprobe overlay     2>/dev/null || true
    modprobe br_netfilter 2>/dev/null || true
    modprobe xt_conntrack 2>/dev/null || true

    # Enable IP forwarding
    echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null || true

    # Start dockerd
    start-stop-daemon --start --quiet --background \
      --pidfile "$PIDFILE" --make-pidfile \
      --exec /usr/bin/dockerd -- $DOCKER_OPTS >> "$LOGFILE" 2>&1

    # Wait up to 60s for the socket (first boot is slow due to storage init)
    RETRIES=60
    while [ ! -S /var/run/docker.sock ] && [ "$RETRIES" -gt 0 ]; do
      sleep 1
      RETRIES=$((RETRIES - 1))
    done

    if [ -S /var/run/docker.sock ]; then
      echo "Docker started."
    else
      echo "ERROR: Docker socket not available after 60s. Check $LOGFILE" >&2
      tail -20 "$LOGFILE" >&2 2>/dev/null || true
    fi
    ;;
  stop)
    echo "Stopping Docker..."
    start-stop-daemon --stop --quiet --pidfile "$PIDFILE"
    rm -f "$PIDFILE"
    ;;
  restart)
    "$0" stop; sleep 2; "$0" start
    ;;
  status)
    if [ -S /var/run/docker.sock ]; then
      echo "Docker is running."
      docker info --format 'Containers: {{.Containers}}  Images: {{.Images}}' 2>/dev/null || true
    else
      echo "Docker is NOT running."
      [ -f "$LOGFILE" ] && tail -5 "$LOGFILE"
    fi
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
esac
