#!/bin/sh
# /etc/init.d/S30cgroupfs — Mount cgroup2 unified hierarchy
# Must run before S30docker (alphabetical: cgroupfs < docker).

case "$1" in
  start)
    if mountpoint -q /sys/fs/cgroup 2>/dev/null; then
      echo "Mounting cgroupfs hierarchy: already mounted"
      exit 0
    fi

    echo -n "Mounting cgroupfs hierarchy: "

    # cgroup2 unified hierarchy (required by modern containerd/runc)
    if mount -t cgroup2 cgroup2 /sys/fs/cgroup; then
      echo "OK"
    else
      # cgroup v1 fallback — mount each controller individually
      mount -t tmpfs tmpfs /sys/fs/cgroup -o mode=755,size=64m || \
        { echo "FAIL"; exit 1; }
      for subsys in cpu cpuacct cpuset memory blkio devices freezer net_cls pids; do
        mkdir -p "/sys/fs/cgroup/${subsys}"
        mount -t cgroup cgroup "/sys/fs/cgroup/${subsys}" -o "${subsys}" 2>/dev/null || true
      done
      echo "OK (cgroup v1)"
    fi
    ;;
  stop|restart) ;;
  *)
    echo "Usage: $0 {start|stop}"
    exit 1
esac
