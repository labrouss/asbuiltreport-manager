#!/bin/sh
# /etc/init.d/S10network — network bringup
# Reads /etc/network/config written by S05ovf-init
. /etc/network/config 2>/dev/null || true

case "$1" in
  start)
    echo "Starting network..."
    # Bring up loopback
    ip link set lo up
    ip addr add 127.0.0.1/8 dev lo 2>/dev/null || true

    # Bring up first ethernet interface
    IFACE=$(ip -o link show | awk -F': ' '!/lo/{print $2; exit}')
    [ -z "$IFACE" ] && IFACE="eth0"

    ip link set "$IFACE" up

    if [ "$NETWORK_MODE" = "static" ] && [ -n "$IP_CIDR" ]; then
      ip addr add "$IP_CIDR" dev "$IFACE"
      [ -n "$GATEWAY" ] && ip route add default via "$GATEWAY"
      # Write resolv.conf
      > /etc/resolv.conf
      for dns in $DNS_SERVERS; do
        echo "nameserver $dns" >> /etc/resolv.conf
      done
      echo "Static IP configured: $IP_CIDR"
    else
      udhcpc -i "$IFACE" -s /usr/share/udhcpc/default.script -b -q
      echo "DHCP configured on $IFACE"
    fi
    ;;
  stop)
    echo "Stopping network..."
    ip link set lo down 2>/dev/null || true
    IFACE=$(ip -o link show | awk -F': ' '!/lo/{print $2; exit}')
    [ -n "$IFACE" ] && ip link set "$IFACE" down
    ;;
  restart)
    "$0" stop; "$0" start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
esac
