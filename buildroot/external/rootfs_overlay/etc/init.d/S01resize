#!/bin/sh
# /etc/init.d/S01resize — Expand rootfs partition + filesystem on first boot
#
# The OVA ships with a 6 GB rootfs. vCenter provisions the VMDK at 40 GB.
# Steps:
#   1. Use parted to resize the rootfs partition to fill the disk
#   2. Use resize2fs to expand the ext4 filesystem into the new space
#
# This runs as the FIRST init script (S01) so disk space is available for all
# subsequent scripts including Docker image loading (S40).

SENTINEL="/var/lib/asbuiltreport/.resize-done"

case "$1" in
  start)
    if [ -f "$SENTINEL" ]; then
      exit 0
    fi

    # Find root device and disk
    ROOT_DEV=$(findmnt -n -o SOURCE / 2>/dev/null || echo "/dev/sda2")
    DISK=$(echo "$ROOT_DEV" | sed 's/[0-9]*$//')    # /dev/sda2 → /dev/sda
    PART_NUM=$(echo "$ROOT_DEV" | grep -oE '[0-9]+$') # /dev/sda2 → 2

    DISK_SECTORS=$(cat /sys/class/block/$(basename $DISK)/size 2>/dev/null || echo 0)
    PART_SECTORS=$(cat /sys/class/block/$(basename $ROOT_DEV)/size 2>/dev/null || echo 0)

    echo "Checking disk expansion:"
    echo "  Disk:      $DISK  ($DISK_SECTORS sectors)"
    echo "  Partition: $ROOT_DEV  ($PART_SECTORS sectors)"

    # If disk is significantly larger than partition, expand
    if [ "$DISK_SECTORS" -gt $(( PART_SECTORS + 1024 )) ]; then
      echo "  → Expanding partition $PART_NUM to fill disk..."

      # Resize the partition using parted
      # 'resizepart' requires the partition number and new end
      parted -s "$DISK" resizepart "$PART_NUM" "100%" 2>/dev/null || \
        parted -s "$DISK" resizepart "$PART_NUM" -- "-1s" 2>/dev/null || true

      # Inform kernel of the new partition size
      partprobe "$DISK" 2>/dev/null || blockdev --rereadpt "$DISK" 2>/dev/null || true

      # Small delay for kernel to re-read partition table
      sleep 1

      # Now expand the filesystem to fill the new partition size
      echo "  → Expanding filesystem..."
      if resize2fs "$ROOT_DEV"; then
        echo "  → Done. New size: $(df -h / | awk 'NR==2{print $2}')"
      else
        echo "  → WARNING: resize2fs failed" >&2
      fi
    else
      echo "  → Already at full size, skipping."
    fi

    mkdir -p "$(dirname $SENTINEL)"
    touch "$SENTINEL"
    ;;
  stop|restart) ;;
  *)
    echo "Usage: $0 {start|stop}"
    exit 1
esac
