#!/bin/sh
# /etc/init.d/S01resize — Fix GPT + extend partition + grow filesystem on first boot

SENTINEL="/var/lib/asbuiltreport/.resize-done"

case "$1" in
  start)
    [ -f "$SENTINEL" ] && exit 0

    ROOT_DEV=$(findmnt -n -o SOURCE / 2>/dev/null || echo "/dev/sda2")
    DISK=$(echo "$ROOT_DEV" | sed 's/[0-9]*$//')
    PART_NUM=$(echo "$ROOT_DEV" | grep -oE '[0-9]+$')

    DISK_SECTORS=$(cat /sys/class/block/$(basename "$DISK")/size 2>/dev/null || echo 0)
    PART_SECTORS=$(cat /sys/class/block/$(basename "$ROOT_DEV")/size 2>/dev/null || echo 0)
    PART_START=$(cat /sys/class/block/$(basename "$DISK")/$(basename "$ROOT_DEV")/start 2>/dev/null || echo 1048610)
    PART_END=$(( PART_START + PART_SECTORS - 1 ))
    AVAILABLE=$(( DISK_SECTORS - PART_END - 34 ))

    echo "S01resize: disk=${DISK_SECTORS} sectors  partition ends=${PART_END}  free=${AVAILABLE}"

    if [ "$AVAILABLE" -lt 204800 ]; then
      echo "S01resize: already full size, skipping."
      mkdir -p "$(dirname $SENTINEL)" && touch "$SENTINEL"
      exit 0
    fi

    echo "S01resize: $(( AVAILABLE / 2048 )) MiB to claim — expanding..."

    # Step 1: Fix GPT backup header (move it to physical end of disk)
    if command -v sgdisk >/dev/null 2>&1; then
      echo "  sgdisk -e: fixing GPT backup..."
      sgdisk -e "$DISK" && echo "  sgdisk: OK" || echo "  sgdisk: WARN"
    else
      echo "  parted print fix: fixing GPT backup..."
      printf "fix\n" | parted ---pretend-input-tty "$DISK" print >/dev/null 2>&1 || true
    fi

    # Step 2: Resize the partition to fill the disk
    echo "  Resizing partition $PART_NUM to 100%..."
    parted -s "$DISK" resizepart "$PART_NUM" 100% \
      && echo "  resizepart: OK" \
      || echo "  resizepart: WARN rc=$?"

    # Reload partition table
    partprobe "$DISK" 2>/dev/null || blockdev --rereadpt "$DISK" 2>/dev/null || true
    sleep 2

    # Step 3: Grow ext4 filesystem to fill the new partition
    echo "  Growing filesystem..."
    resize2fs "$ROOT_DEV" \
      && echo "S01resize: done — $(df -h / | awk 'NR==2{print $2}') total" \
      || echo "S01resize: resize2fs WARN" >&2

    mkdir -p "$(dirname $SENTINEL)"
    touch "$SENTINEL"
    ;;
  stop|restart) ;;
  *)
    echo "Usage: $0 {start|stop}"
    exit 1
esac
