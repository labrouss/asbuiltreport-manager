#!/bin/sh
# /etc/init.d/S32ovf-init
#
# OVF Lifecycle:
#   INPUT  (our template):  plain ovf:key="guestinfo.hostname" — no oe: prefix
#   OUTPUT (VMware builds): <Property oe:key="guestinfo.hostname" oe:value="..."/>
#
# Strategy: fetch guestinfo.ovfEnv ONCE via vmtoolsd, save XML to disk,
# parse locally on all subsequent boots. Never query VMware again after
# the sentinel is written.

CONFIG_DIR="/var/lib/asbuiltreport/config"
OVF_XML="${CONFIG_DIR}/ovf_env.xml"
ENV_FILE="${CONFIG_DIR}/ovf_env.sh"
SENTINEL="${CONFIG_DIR}/.provisioned"

# ── Parse a property from the saved OVF environment XML ───────────────────
# VMware generates: <Property oe:key="guestinfo.hostname" oe:value="value"/>
parse_ovf() {
    local key="$1"
    grep -o "key=\"${key}\" oe:value=\"[^\"]*\"" "$OVF_XML" 2>/dev/null \
        | sed 's/.*oe:value="\([^"]*\)"/\1/' | head -1
}

# ── Set root password ──────────────────────────────────────────────────────
set_root_password() {
    local pw="$1"
    [ -z "$pw" ] && return
    if command -v chpasswd >/dev/null 2>&1; then
        printf 'root:%s' "$pw" | chpasswd
    elif command -v openssl >/dev/null 2>&1; then
        local hash
        hash=$(openssl passwd -6 "$pw" 2>/dev/null)
        [ -n "$hash" ] && sed -i "s|^root:[^:]*:|root:${hash}:|" /etc/shadow 2>/dev/null
    else
        printf '%s\n%s\n' "$pw" "$pw" | passwd root 2>/dev/null
    fi
}

# ── Apply configuration from ENV_FILE ─────────────────────────────────────
apply_config() {
    [ -f "$ENV_FILE" ] || return
    . "$ENV_FILE"

    [ -n "$OVF_HOSTNAME" ] \
        && echo "$OVF_HOSTNAME" > /etc/hostname \
        && hostname "$OVF_HOSTNAME" \
        && echo "  hostname : $OVF_HOSTNAME"

    if [ -n "$OVF_IP_CIDR" ]; then
        mkdir -p /etc/network
        cat > /etc/network/config << EOF
INTERFACE=eth0
MODE=static
IP_CIDR=$OVF_IP_CIDR
GATEWAY=${OVF_GATEWAY:-}
DNS=${OVF_DNS:-8.8.8.8}
EOF
        echo "  network  : $OVF_IP_CIDR gw=${OVF_GATEWAY:-dhcp}"
    fi

    if [ -n "$OVF_PASSWORD" ]; then
        set_root_password "$OVF_PASSWORD"
        passwd -e root 2>/dev/null || true
        /etc/init.d/S50ttyd start 2>/dev/null || true
        echo "  password : configured (change required on first login)"
    fi

    if [ -n "$OVF_SSH_KEY" ]; then
        mkdir -p /root/.ssh && chmod 700 /root/.ssh
        grep -qF "$OVF_SSH_KEY" /root/.ssh/authorized_keys 2>/dev/null \
            || echo "$OVF_SSH_KEY" >> /root/.ssh/authorized_keys
        chmod 600 /root/.ssh/authorized_keys
        echo "  ssh key  : installed"
    fi
}

# ── Main ───────────────────────────────────────────────────────────────────
case "$1" in
  start)
    mkdir -p "$CONFIG_DIR" && chmod 700 "$CONFIG_DIR"

    # Subsequent boots: read from local disk, never query VMware
    if [ -f "$SENTINEL" ]; then
        echo "OVF: applying saved configuration..."
        apply_config
        exit 0
    fi

    # First boot: fetch the OVF environment XML from VMware — one shot
    echo "OVF: first boot — querying guestinfo.ovfEnv..."

    # Wait for vmtoolsd daemon inside container to be ready
    i=0
    while [ $i -lt 5 ]; do
        docker exec asbuiltreport-vmware-tools \
            vmtoolsd --cmd "ping" >/dev/null 2>&1 && break
        sleep 2; i=$((i+1))
    done

    RAW_XML=$(docker exec asbuiltreport-vmware-tools \
        vmtoolsd --cmd "info-get guestinfo.ovfEnv" 2>/dev/null)

    # Filter out "No value found" response
    [ "$RAW_XML" = "No value found" ] && RAW_XML=""

    if [ -z "$RAW_XML" ]; then
        echo "OVF: guestinfo.ovfEnv not available"
        echo "OVF: ensure VM was deployed via OVA wizard with properties filled in"
        echo "OVF: falling back to abr-setup wizard on first login"
        exit 0
    fi

    echo "OVF: received $(printf '%s' "$RAW_XML" | wc -c) bytes"

    # Save raw XML — permanent local copy, never need VMware again
    printf '%s' "$RAW_XML" > "$OVF_XML"
    chmod 600 "$OVF_XML"

    # Parse all properties from the VMware-generated XML
    OVF_HOSTNAME=$(parse_ovf "guestinfo.hostname")
    OVF_IP_CIDR=$(parse_ovf  "guestinfo.ipaddress")
    OVF_GATEWAY=$(parse_ovf  "guestinfo.gateway")
    OVF_DNS=$(parse_ovf      "guestinfo.dns")
    OVF_PASSWORD=$(parse_ovf "guestinfo.password")
    OVF_SSH_KEY=$(parse_ovf  "guestinfo.ssh_authorized_key")

    # Persist parsed values
    cat > "$ENV_FILE" << EOF
# OVF configuration — parsed from guestinfo.ovfEnv
# Written: $(date -u +%Y-%m-%dT%H:%M:%SZ)
# To re-provision: S32ovf-init reprovision && reboot
OVF_HOSTNAME='${OVF_HOSTNAME}'
OVF_IP_CIDR='${OVF_IP_CIDR}'
OVF_GATEWAY='${OVF_GATEWAY}'
OVF_DNS='${OVF_DNS}'
OVF_PASSWORD='${OVF_PASSWORD}'
OVF_SSH_KEY='${OVF_SSH_KEY}'
EOF
    chmod 600 "$ENV_FILE"

    # Drop sentinel — done with VMware forever
    touch "$SENTINEL"
    echo "OVF: provisioning complete — configuration saved to ${ENV_FILE}"

    apply_config
    ;;

  reprovision)
    rm -f "$SENTINEL"
    echo "OVF: sentinel cleared — will re-fetch guestinfo.ovfEnv on next boot"
    ;;

  stop) ;;
  *) echo "Usage: $0 {start|reprovision}"; exit 1 ;;
esac
