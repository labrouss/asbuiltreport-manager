#!/bin/sh
# /etc/init.d/S25vmtools — VMware tools heartbeat daemon
#
# Keeps the VMware guestinfo channel alive so vCenter can read/write
# guestinfo.* properties. Without this VMware marks tools as "unknown"
# and the guestinfo backdoor channel goes idle after boot.
#
# This is a minimal replacement for vmtoolsd's heartbeat functionality.
# It uses vmware-rpctool to send periodic pings to the hypervisor and
# report the guest IP address.

PIDFILE=/var/run/vmtools-heartbeat.pid
INTERVAL=30

heartbeat_loop() {
    while true; do
        # Send tools heartbeat — tells VMware tools are running
        vmware-rpctool "tools.set.version 2147483647" 2>/dev/null || true
        vmware-rpctool "tools.capability.hb_res 1" 2>/dev/null || true

        # Report current IP address to vCenter (shows in VM summary)
        IP=$(ip -4 addr show scope global 2>/dev/null | \
             grep -oE 'inet [0-9.]+' | head -1 | cut -d' ' -f2)
        if [ -n "$IP" ]; then
            vmware-rpctool "info-set guestinfo.ip $IP" 2>/dev/null || true
        fi

        sleep "$INTERVAL"
    done
}

case "$1" in
  start)
    if ! command -v vmware-rpctool >/dev/null 2>&1; then
        echo "vmtools heartbeat: vmware-rpctool not found, skipping"
        exit 0
    fi
    # Quick check we're in VMware
    if ! vmware-rpctool "tools.set.version 2147483647" 2>/dev/null; then
        echo "vmtools heartbeat: not in VMware, skipping"
        exit 0
    fi
    echo -n "Starting VMware tools heartbeat... "
    heartbeat_loop &
    echo $! > "$PIDFILE"
    echo "OK (pid $(cat $PIDFILE))"
    ;;
  stop)
    echo -n "Stopping VMware tools heartbeat... "
    [ -f "$PIDFILE" ] && kill "$(cat $PIDFILE)" 2>/dev/null && rm -f "$PIDFILE"
    echo "OK"
    ;;
  restart) "$0" stop; sleep 1; "$0" start ;;
  status)
    [ -f "$PIDFILE" ] && kill -0 "$(cat $PIDFILE)" 2>/dev/null \
        && echo "VMware tools heartbeat running (pid $(cat $PIDFILE))" \
        || echo "VMware tools heartbeat not running"
    ;;
  *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
