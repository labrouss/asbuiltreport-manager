#!/bin/sh
# /etc/init.d/S31vmware-tools
# Starts the vmware-tools container after Docker (S30docker).
# S32ovf-init depends on this container to read OVF guestinfo on first boot.
# Managed exclusively here — NOT in docker-compose (avoids name conflicts).

CONTAINER="asbuiltreport-vmware-tools"
IMAGE="asbuiltreport-vmware-tools:latest"
PRELOAD_DIR="/var/lib/docker-preload"

case "$1" in
  start)
    # Already running — nothing to do
    if docker inspect --format='{{.State.Running}}' "$CONTAINER" \
       2>/dev/null | grep -q true; then
        echo "vmware-tools container already running"
        exit 0
    fi

    # Remove any stopped container with the same name
    docker rm -f "$CONTAINER" 2>/dev/null || true

    # Load image if not present
    if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
        TARBALL="${PRELOAD_DIR}/asbuiltreport-vmware-tools.tar.gz"
        if [ -f "$TARBALL" ]; then
            echo "Loading vmware-tools image..."
            gunzip -c "$TARBALL" | docker load
        else
            echo "S31vmware-tools: image not available, skipping"
            exit 0
        fi
    fi

    echo -n "Starting vmware-tools container... "
    docker run -d \
        --name "$CONTAINER" \
        --restart unless-stopped \
        --privileged \
        --pid host \
        --network host \
        -v /var/run:/var/run \
        "$IMAGE" \
        && echo "OK" \
        || echo "FAILED"
    ;;

  stop)
    echo -n "Stopping vmware-tools container... "
    docker rm -f "$CONTAINER" 2>/dev/null && echo "OK" || echo "not running"
    ;;

  restart) "$0" stop; sleep 1; "$0" start ;;

  status)
    docker inspect --format='{{.State.Status}}' "$CONTAINER" 2>/dev/null \
        || echo "not running"
    ;;

  *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
