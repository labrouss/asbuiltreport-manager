#!/bin/sh
# /etc/init.d/S05ovf-init
# Reads VMware guestinfo OVF properties and configures the system.
# Runs every boot but only applies password/SSH key on first run.

SENTINEL="/var/lib/asbuiltreport/.ovf-init-done"

get_guestinfo() {
    local key="$1"
    local val=""

    # Method 1: vmware-rpctool backdoor (requires heartbeat channel to be open)
    if command -v vmware-rpctool >/dev/null 2>&1; then
        val=$(vmware-rpctool "info-get guestinfo.${key}" 2>/dev/null)
    fi

    # Method 2: OVF environment XML delivered via guestinfo.ovfenv
    if [ -z "$val" ] && command -v vmware-rpctool >/dev/null 2>&1; then
        local ovfenv
        ovfenv=$(vmware-rpctool "info-get guestinfo.ovfenv" 2>/dev/null)
        if [ -n "$ovfenv" ]; then
            # Parse: <Property oe:key="hostname" oe:value="myhost"/>
            val=$(printf '%s' "$ovfenv" | \
                  grep -o "key=\"${key}\" oe:value=\"[^\"]*\"" | \
                  sed 's/.*oe:value="\([^"]*\)"/\1/' | head -1)
            # Also try without oe: prefix
            if [ -z "$val" ]; then
                val=$(printf '%s' "$ovfenv" | \
                      grep -o "key=\"${key}\" ovf:value=\"[^\"]*\"" | \
                      sed 's/.*ovf:value="\([^"]*\)"/\1/' | head -1)
            fi
        fi
    fi

    printf '%s' "$val"
}

case "$1" in
  start)
    echo "Reading OVF properties..."

    HOSTNAME=$(get_guestinfo hostname)
    IP_CIDR=$(get_guestinfo ipaddress)
    GATEWAY=$(get_guestinfo gateway)
    DNS_SERVERS=$(get_guestinfo dns)
    PASSWORD=$(get_guestinfo password)
    SSH_KEY=$(get_guestinfo ssh_authorized_key)

    # Apply hostname
    if [ -n "$HOSTNAME" ]; then
        echo "$HOSTNAME" > /etc/hostname
        hostname "$HOSTNAME"
    fi

    # Apply network (static or DHCP — handled by S10network)
    if [ -n "$IP_CIDR" ]; then
        mkdir -p /etc/network
        cat > /etc/network/config << EOF
INTERFACE=eth0
IP_CIDR=$IP_CIDR
GATEWAY=$GATEWAY
DNS=$DNS_SERVERS
EOF
    fi

    # One-time: password and SSH key
    if [ ! -f "$SENTINEL" ]; then
        if [ -n "$PASSWORD" ]; then
            echo "root:$PASSWORD" | chpasswd
            # Force password change on first login
            chage -d 0 root 2>/dev/null || passwd -e root 2>/dev/null || true
            # Start ttyd now that a password is set
            /etc/init.d/S50ttyd start 2>/dev/null || true
        fi

        if [ -n "$SSH_KEY" ]; then
            mkdir -p /root/.ssh
            chmod 700 /root/.ssh
            echo "$SSH_KEY" >> /root/.ssh/authorized_keys
            chmod 600 /root/.ssh/authorized_keys
        fi

        mkdir -p "$(dirname $SENTINEL)"
        touch "$SENTINEL"
    fi

    echo "OVF init complete."
    ;;
  stop) ;;
  *) echo "Usage: $0 {start|stop}"; exit 1 ;;
esac
