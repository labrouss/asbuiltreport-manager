#!/bin/sh
# /etc/init.d/S05ovf-init
#
# First-boot: queries VMware guestinfo, saves config to local disk, sets sentinel.
# Subsequent boots: reads from local disk only — never queries VMware again.
#
# This pattern guarantees config survives vMotion, HA restart, snapshot
# consolidation, and any other event that flushes VMware's runtime guestInfo cache.

CONFIG_DIR="/var/lib/asbuiltreport/config"
ENV_FILE="${CONFIG_DIR}/ovf_env.sh"
SENTINEL="${CONFIG_DIR}/.provisioned"

# ── Password utility ───────────────────────────────────────────────────────
set_root_password() {
    local pw="$1"
    [ -z "$pw" ] && return
    if command -v chpasswd >/dev/null 2>&1; then
        printf 'root:%s' "$pw" | chpasswd
    elif command -v openssl >/dev/null 2>&1; then
        local hash
        hash=$(openssl passwd -6 "$pw" 2>/dev/null)
        [ -n "$hash" ] && sed -i "s|^root:[^:]*:|root:${hash}:|" /etc/shadow 2>/dev/null
    else
        printf '%s\n%s\n' "$pw" "$pw" | passwd root 2>/dev/null
    fi
}

# ── Read one guestinfo key via Docker privileged container ─────────────────
get_guestinfo() {
    local key="$1"
    if command -v docker >/dev/null 2>&1 && \
       docker inspect --format='{{.State.Running}}' \
           asbuiltreport-vmware-tools 2>/dev/null | grep -q true; then
        docker exec asbuiltreport-vmware-tools \
            vmware-rpctool "info-get guestinfo.${key}" 2>/dev/null
    fi
}

# ── Apply config from ENV_FILE ─────────────────────────────────────────────
apply_config() {
    # shellcheck source=/dev/null
    . "$ENV_FILE"

    [ -n "$OVF_HOSTNAME" ] && echo "$OVF_HOSTNAME" > /etc/hostname && hostname "$OVF_HOSTNAME"

    if [ -n "$OVF_IP_CIDR" ]; then
        mkdir -p /etc/network
        cat > /etc/network/config << EOF
INTERFACE=eth0
MODE=static
IP_CIDR=$OVF_IP_CIDR
GATEWAY=${OVF_GATEWAY:-}
DNS=${OVF_DNS:-8.8.8.8}
EOF
    fi

    [ -n "$OVF_PASSWORD" ] && set_root_password "$OVF_PASSWORD"

    if [ -n "$OVF_SSH_KEY" ]; then
        mkdir -p /root/.ssh && chmod 700 /root/.ssh
        grep -qF "$OVF_SSH_KEY" /root/.ssh/authorized_keys 2>/dev/null || \
            echo "$OVF_SSH_KEY" >> /root/.ssh/authorized_keys
        chmod 600 /root/.ssh/authorized_keys
    fi

    [ -n "$OVF_PASSWORD" ] && /etc/init.d/S50ttyd start 2>/dev/null || true
}

# ── Main ───────────────────────────────────────────────────────────────────
case "$1" in
  start)
    mkdir -p "$CONFIG_DIR"

    if [ -f "$SENTINEL" ]; then
        # ── Subsequent boots: read from local disk ─────────────────────────
        echo "OVF: using saved configuration from ${ENV_FILE}"
        [ -f "$ENV_FILE" ] && apply_config
        exit 0
    fi

    # ── First boot: query VMware ───────────────────────────────────────────
    echo "OVF: first boot — querying VMware guestinfo..."

    OVF_HOSTNAME=$(get_guestinfo hostname)
    OVF_IP_CIDR=$(get_guestinfo ipaddress)
    OVF_GATEWAY=$(get_guestinfo gateway)
    OVF_DNS=$(get_guestinfo dns)
    OVF_PASSWORD=$(get_guestinfo password)
    OVF_SSH_KEY=$(get_guestinfo ssh_authorized_key)

    if [ -z "${OVF_HOSTNAME}${OVF_IP_CIDR}${OVF_PASSWORD}${OVF_SSH_KEY}" ]; then
        echo "OVF: no properties found — setup wizard will run on first login"
        exit 0
    fi

    # Save to local persistent storage
    cat > "$ENV_FILE" << EOF
# OVF configuration — written on first boot $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Do not edit: regenerate with 'rm ${SENTINEL} && reboot'
OVF_HOSTNAME='${OVF_HOSTNAME}'
OVF_IP_CIDR='${OVF_IP_CIDR}'
OVF_GATEWAY='${OVF_GATEWAY}'
OVF_DNS='${OVF_DNS}'
OVF_PASSWORD='${OVF_PASSWORD}'
OVF_SSH_KEY='${OVF_SSH_KEY}'
EOF
    chmod 600 "$ENV_FILE"

    # Drop sentinel — never query VMware again
    touch "$SENTINEL"
    echo "OVF: configuration saved to ${ENV_FILE}"

    apply_config
    ;;

  reprovision)
    # Force re-read from VMware on next boot
    rm -f "$SENTINEL"
    echo "OVF: sentinel removed — will re-query VMware on next boot"
    ;;

  stop) ;;
  *) echo "Usage: $0 {start|reprovision}"; exit 1 ;;
esac
