#!/bin/sh
# /etc/init.d/S05ovf-init
# Reads OVF guestinfo properties and pre-configures the appliance.
# Runs early (position 05) for hostname/network, and again post-Docker (via
# S40asbuiltreport) using the privileged vmware-tools container for password/SSH.
# If no properties are available, the first-login wizard (abr-setup) handles setup.

SENTINEL="/var/lib/asbuiltreport/.ovf-init-done"

# ── Read a guestinfo property ──────────────────────────────────────────────
get_guestinfo() {
    local key="$1"

    # Via privileged Docker container (works on ESXi, needs Docker running)
    if command -v docker >/dev/null 2>&1; then
        if docker inspect --format='{{.State.Running}}' \
           asbuiltreport-vmware-tools 2>/dev/null | grep -q true; then
            docker exec asbuiltreport-vmware-tools \
                vmware-rpctool "info-get guestinfo.${key}" 2>/dev/null
            return
        fi
    fi

    # Direct vmware-rpctool (may work on some ESXi configs)
    if command -v vmware-rpctool >/dev/null 2>&1; then
        vmware-rpctool "info-get guestinfo.${key}" 2>/dev/null
    fi
}

case "$1" in
  start)
    HOSTNAME=$(get_guestinfo hostname)
    IP_CIDR=$(get_guestinfo ipaddress)
    GATEWAY=$(get_guestinfo gateway)
    DNS=$(get_guestinfo dns)
    PASSWORD=$(get_guestinfo password)
    SSH_KEY=$(get_guestinfo ssh_authorized_key)

    # Apply hostname (even if no other properties set)
    if [ -n "$HOSTNAME" ]; then
        echo "$HOSTNAME" > /etc/hostname
        hostname "$HOSTNAME"
        echo "OVF: hostname=$HOSTNAME"
    fi

    # Write network config for S10network
    if [ -n "$IP_CIDR" ]; then
        mkdir -p /etc/network
        cat > /etc/network/config << EOF
INTERFACE=eth0
MODE=static
IP_CIDR=$IP_CIDR
GATEWAY=${GATEWAY:-}
DNS=${DNS:-8.8.8.8}
EOF
        echo "OVF: network=$IP_CIDR"
    fi

    # One-time: password + SSH key
    if [ ! -f "$SENTINEL" ]; then
        if [ -n "$PASSWORD" ]; then
            echo "root:$PASSWORD" | chpasswd
            # Mark setup done so wizard doesn't override it
            mkdir -p "$(dirname $SENTINEL)"
            touch "$SENTINEL"
            /etc/init.d/S50ttyd start 2>/dev/null || true
            echo "OVF: password configured"
        fi
        if [ -n "$SSH_KEY" ]; then
            mkdir -p /root/.ssh && chmod 700 /root/.ssh
            echo "$SSH_KEY" >> /root/.ssh/authorized_keys
            chmod 600 /root/.ssh/authorized_keys
            echo "OVF: SSH key installed"
        fi
    fi

    # If nothing was readable, wizard will run on first login
    if [ -z "$HOSTNAME$IP_CIDR$PASSWORD" ]; then
        echo "OVF: no properties available — setup wizard will run on first login"
    fi
    ;;
  stop) ;;
  *) echo "Usage: $0 {start|stop}"; exit 1 ;;
esac
