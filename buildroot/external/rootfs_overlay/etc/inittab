# /etc/inittab — BusyBox init
#
# tty1::sysinit routes rc output to VGA console so boot messages are visible.

# System initialisation — output goes to tty1 (VGA console)
tty1::sysinit:/etc/init.d/rcS

# Serial console getty
ttyS0::respawn:/sbin/getty -L ttyS0 115200 vt100

# VGA console getty (login prompt on tty1 after rcS completes)
tty1::respawn:/sbin/getty -n -l /sbin/login 38400 tty1

# Ctrl-Alt-Del
::ctrlaltdel:/sbin/reboot

# Shutdown
tty1::shutdown:/etc/init.d/rcK
::shutdown:/bin/umount -a -r
::shutdown:/sbin/swapoff -a
