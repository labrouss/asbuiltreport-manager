<?xml version="1.0" encoding="UTF-8"?>
<Envelope xmlns="http://schemas.dmtf.org/ovf/envelope/1"
          xmlns:ovf="http://schemas.dmtf.org/ovf/envelope/1"
          xmlns:rasd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_ResourceAllocationSettingData"
          xmlns:vssd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_VirtualSystemSettingData"
          xmlns:vmw="http://www.vmware.com/schema/ovf"
          xmlns:oe="http://schemas.dmtf.org/ovf/environment/1"
          xml:lang="en-US">

  <References>
    <File ovf:id="disk1" ovf:href="@@VMDK_FILENAME@@" ovf:size="@@VMDK_SIZE_BYTES@@"/>
  </References>

  <DiskSection>
    <Info>Virtual disk information</Info>
    <Disk ovf:diskId="vmdisk1"
          ovf:fileRef="disk1"
          ovf:capacity="@@DISK_SIZE_BYTES@@"
          ovf:capacityAllocationUnits="byte"
          ovf:format="http://www.vmware.com/interfaces/specifications/vmdk.html#streamOptimized"
          ovf:populatedSize="@@VMDK_SIZE_BYTES@@"/>
  </DiskSection>

  <NetworkSection>
    <Info>Logical networks used in the package</Info>
    <Network ovf:name="VM Network">
      <Description>Management network for the AsBuiltReport Manager appliance</Description>
    </Network>
  </NetworkSection>

  <VirtualSystem ovf:id="asbuiltreport-manager">
    <Info>AsBuiltReport Manager Appliance v@@VERSION@@</Info>

    <AnnotationSection>
      <Info>Appliance annotations</Info>
      <Annotation>AsBuiltReport Manager v@@VERSION@@ — Web UI: http://vm-ip:3001</Annotation>
    </AnnotationSection>

    <OperatingSystemSection ovf:id="101" vmw:osType="otherLinux64Guest">
      <Info>Guest operating system</Info>
      <Description>Linux (Buildroot, musl, kernel 6.6 LTS)</Description>
    </OperatingSystemSection>

    <VirtualHardwareSection>
      <Info>Virtual hardware requirements</Info>

      <ovf:System>
        <vssd:ElementName>Virtual Hardware Family</vssd:ElementName>
        <vssd:InstanceID>0</vssd:InstanceID>
        <vssd:VirtualSystemIdentifier>asbuiltreport-manager</vssd:VirtualSystemIdentifier>
        <vssd:VirtualSystemType>vmx-17</vssd:VirtualSystemType>
      </ovf:System>

      <!-- 4 vCPU -->
      <ovf:Item>
        <rasd:Description>Number of virtual CPUs</rasd:Description>
        <rasd:ElementName>4 virtual CPU(s)</rasd:ElementName>
        <rasd:InstanceID>1</rasd:InstanceID>
        <rasd:ResourceType>3</rasd:ResourceType>
        <rasd:VirtualQuantity>4</rasd:VirtualQuantity>
      </ovf:Item>

      <!-- 8 GB RAM -->
      <ovf:Item>
        <rasd:AllocationUnits>byte * 2^20</rasd:AllocationUnits>
        <rasd:Description>Memory Size</rasd:Description>
        <rasd:ElementName>8192 MB of memory</rasd:ElementName>
        <rasd:InstanceID>2</rasd:InstanceID>
        <rasd:ResourceType>4</rasd:ResourceType>
        <rasd:VirtualQuantity>8192</rasd:VirtualQuantity>
      </ovf:Item>

      <!-- SATA Controller (matches adapter_type=lsilogic in VMDK but vCenter
           maps streamOptimized VMDKs to SATA for EFI VMs) -->
      <ovf:Item>
        <rasd:Description>SATA Controller</rasd:Description>
        <rasd:ElementName>SATA controller 0</rasd:ElementName>
        <rasd:InstanceID>3</rasd:InstanceID>
        <rasd:ResourceSubType>vmware.sata.ahci</rasd:ResourceSubType>
        <rasd:ResourceType>20</rasd:ResourceType>
      </ovf:Item>

      <!-- Hard disk attached to SATA controller -->
      <ovf:Item>
        <rasd:AddressOnParent>0</rasd:AddressOnParent>
        <rasd:Description>Disk image</rasd:Description>
        <rasd:ElementName>Hard disk 1</rasd:ElementName>
        <rasd:HostResource>ovf:/disk/vmdisk1</rasd:HostResource>
        <rasd:InstanceID>4</rasd:InstanceID>
        <rasd:Parent>3</rasd:Parent>
        <rasd:ResourceType>17</rasd:ResourceType>
      </ovf:Item>

      <!-- VMXNET3 NIC -->
      <ovf:Item>
        <rasd:AddressOnParent>0</rasd:AddressOnParent>
        <rasd:AutomaticAllocation>true</rasd:AutomaticAllocation>
        <rasd:Connection>VM Network</rasd:Connection>
        <rasd:Description>VMXNET3 ethernet adapter</rasd:Description>
        <rasd:ElementName>Network adapter 1</rasd:ElementName>
        <rasd:InstanceID>5</rasd:InstanceID>
        <rasd:ResourceSubType>VMXNET3</rasd:ResourceSubType>
        <rasd:ResourceType>10</rasd:ResourceType>
      </ovf:Item>

      <!-- EFI firmware — required for GRUB2 EFI boot, must match disk layout -->
      <vmw:Config ovf:required="false" vmw:key="firmware" vmw:value="efi"/>
      <vmw:Config ovf:required="false" vmw:key="uefi.secureBoot.enabled" vmw:value="false"/>

    </VirtualHardwareSection>

    <!-- OVF Properties — configurable at deploy time in vCenter -->
    <ProductSection ovf:required="false" ovf:transport="com.vmware.guestInfo iso">
      <Info>Application configuration properties</Info>
      <Product>AsBuiltReport Manager</Product>
      <Vendor>AsBuiltReport</Vendor>
      <Version>@@VERSION@@</Version>
      <FullVersion>@@VERSION@@</FullVersion>
      <ProductUrl>https://www.asbuiltreport.com</ProductUrl>

      <Property ovf:key="guestinfo.hostname"
                ovf:type="string"
                ovf:userConfigurable="true"
                ovf:value="asbuiltreport-manager">
        <Label>Hostname</Label>
        <Description>Appliance hostname (e.g. abr.company.local)</Description>
      </Property>

      <Property ovf:key="guestinfo.ipaddress"
                ovf:type="string"
                ovf:userConfigurable="true"
                ovf:value="">
        <Label>IP Address (CIDR)</Label>
        <Description>Static IP in CIDR notation e.g. 192.168.1.50/24. Leave blank for DHCP.</Description>
      </Property>

      <Property ovf:key="guestinfo.gateway"
                ovf:type="string"
                ovf:userConfigurable="true"
                ovf:value="">
        <Label>Default Gateway</Label>
        <Description>Default gateway IP. Required if static IP is set.</Description>
      </Property>

      <Property ovf:key="guestinfo.dns"
                ovf:type="string"
                ovf:userConfigurable="true"
                ovf:value="8.8.8.8 8.8.4.4">
        <Label>DNS Servers</Label>
        <Description>Space-separated DNS server IPs.</Description>
      </Property>

      <Property ovf:key="guestinfo.password"
                ovf:type="password"
                ovf:userConfigurable="true"
                ovf:value="">
        <Label>Root Password</Label>
        <Description>Initial root password. Leave blank to disable password auth (SSH key only).</Description>
      </Property>

      <Property ovf:key="guestinfo.ssh_authorized_key"
                ovf:type="string"
                ovf:userConfigurable="true"
                ovf:value="">
        <Label>SSH Authorized Key</Label>
        <Description>SSH public key for root login (optional).</Description>
      </Property>
    </ProductSection>

  </VirtualSystem>
</Envelope>
