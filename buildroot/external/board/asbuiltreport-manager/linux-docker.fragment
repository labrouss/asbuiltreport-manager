# linux-docker.fragment
#
# Kernel configuration fragment for Docker + container support.
# Applied on top of the x86_64 defconfig via
# BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES in the Buildroot defconfig.
#
# Mirrors the san-manager linux-docker.fragment exactly.

# ── devtmpfs — kernel auto-mounts /dev before init ───────────────────────────
# Required so that /dev/sda2, /dev/null etc. exist when rcS runs.
# Without this /dev is empty and mkdir /dev/pts fails.
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── Namespaces (required by all container runtimes) ───────────────────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# ── Cgroups v1 — full controller set required by Docker/runc ─────────────────
# S30cgroupfs mounts cgroup v1 hierarchy. runc uses BPF_CGROUP_DEVICE which
# requires cgroup v1 controllers (cpu, memory, devices, cpuset, blkio, pids).
# All controllers must be compiled in to silence dockerd warnings.
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_RT_GROUP_SCHED=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_CGROUP_THROTTLE=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_NET_CLASSID=y
CONFIG_CGROUP_NET_PRIO=y

# ── Overlay filesystem (Docker storage driver) ────────────────────────────────
CONFIG_OVERLAY_FS=y

# ── Network virtualisation ────────────────────────────────────────────────────
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_IPV4=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_MANGLE=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y

# ── nftables (replaces iptables in newer Docker) ──────────────────────────────
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_CT=y

# ── Seccomp (Docker default security profile) ─────────────────────────────────
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# ── AppArmor / capabilities ────────────────────────────────────────────────────
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y

# ── BPF — required by runc cgroup device policy (cgroup v1 + v2) ─────────────
# Without these runc fails: "bpf_prog_query(BPF_CGROUP_DEVICE) failed:
#   function not implemented"
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_CGROUP_BPF=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# ── Misc required by containerd / runc ───────────────────────────────────────
CONFIG_POSIX_MQUEUE=y
CONFIG_DEVPTS_MULTIPLE_INSTANCES=y
CONFIG_HUGETLBFS=y

# ── VMware VMXNET3 NIC ────────────────────────────────────────────────────────
CONFIG_VMXNET3=y

# ── VMware PVSCSI storage ─────────────────────────────────────────────────────
CONFIG_SCSI_PVSCSI=y

# ── EFI runtime ──────────────────────────────────────────────────────────────
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=y

# ── EFI Framebuffer console (required for VGA output in VMware VMRC) ─────────
# Without these the screen goes blank after GRUB hands off to the kernel.
# EFI hands the framebuffer to the kernel; CONFIG_FB_EFI makes the kernel
# use it as a console device visible in VMware's web/remote console.
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_DUMMY_CONSOLE=y
CONFIG_VGA_CONSOLE=y
# VMware SVGA driver (optional — FB_EFI works without it but SVGA gives
# proper resolution negotiation with VMware's virtual GPU)
CONFIG_DRM=y
CONFIG_DRM_VMWGFX=y
CONFIG_DRM_FBDEV_EMULATION=y
